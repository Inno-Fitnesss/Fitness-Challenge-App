# Запросы идут через Vite proxy → http://localhost:8000 (обходит CORS)
VITE_API_BASE_URL=/api
# OAuth 2.0 Client ID из Google Cloud Console (тот же, что GOOGLE_CLIENT_ID бэкенда).
# Пусто — кнопка "Войти через Google" скрыта.
VITE_GOOGLE_CLIENT_ID=
# Optional local override: true forces the mobile app, false forces desktop.
# In production the mobile app is selected automatically on m.* or mobile.* hosts.
VITE_FORCE_MOBILE_APP=
