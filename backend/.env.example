# Copy to .env for local runs without Docker.
DATABASE_URL=postgresql://user:password@localhost:5432/postgres
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
CORS_ORIGINS=*
# Bcrypt hash of the /admin panel password. Generate with:
#   python -c "from app.core.security.hashHelper import HashHelper; print(HashHelper.get_password_hash('your-password'))"
ADMIN_PASSWORD_HASH=$2b$12$aPmveV7uuTP2hwZy3thrzOZeYEB76efdN/meB7Tr7BIpeaU4ae8Z2
# OAuth 2.0 Client ID from Google Cloud Console ("Web application" type).
# Leave empty to disable the "Sign in with Google" endpoint.
GOOGLE_CLIENT_ID=
# SMTP for account emails (password reset, email verification).
#   Gmail: host/port as below, SMTP_USER=the address, SMTP_PASSWORD=an App
#     Password (https://myaccount.google.com/apppasswords, needs 2FA). Here the
#     login is the address, so SMTP_FROM_EMAIL can be left empty.
#   UniOne / relays: SMTP_HOST=smtp.eu1.unione.io, SMTP_USER=<numeric login>,
#     and you MUST set SMTP_FROM_EMAIL to a verified sender (e.g.
#     no-reply@wowfit.pro) — the numeric login is not a valid From address.
# Leave SMTP_USER/SMTP_PASSWORD empty to disable emails — the code is logged
# on the server instead (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=WOWFIT
# Sender/From address. Defaults to SMTP_USER when empty (fine for Gmail).
SMTP_FROM_EMAIL=